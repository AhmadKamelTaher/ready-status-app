@{
    ViewData["Title"] = "Home Page";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-10 text-center">
        <div class="mb-5">
            <i class="bi bi-broadcast text-primary" style="font-size: 6rem;"></i>
            <h1 class="display-3 fw-bold mt-3">Ready Status App</h1>
            <p class="lead text-muted fs-4">Real-time user status monitoring system</p>
        </div>

        <div class="row g-4 mb-5">
            <div class="col-md-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body p-4">
                        <i class="bi bi-person-check text-success" style="font-size: 3rem;"></i>
                        <h4 class="mt-3">User Dashboard</h4>
                        <p class="text-muted">Toggle your ready status with a single click</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body p-4">
                        <i class="bi bi-speedometer2 text-primary" style="font-size: 3rem;"></i>
                        <h4 class="mt-3">Admin Monitor</h4>
                        <p class="text-muted">View all users' status in real-time</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body p-4">
                        <i class="bi bi-lightning text-warning" style="font-size: 3rem;"></i>
                        <h4 class="mt-3">Real-Time Updates</h4>
                        <p class="text-muted">Instant notifications with SignalR</p>
                    </div>
                </div>
            </div>
        </div>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-controller="User" asp-action="Dashboard" class="btn btn-primary btn-lg px-5 py-3">
                <i class="bi bi-arrow-right-circle me-2"></i>Go to Dashboard
            </a>
        }
        else
        {
            <div class="d-flex justify-content-center gap-3">
                <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg px-5 py-3">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Login
                </a>
                <a asp-controller="Account" asp-action="Register" class="btn btn-outline-primary btn-lg px-5 py-3">
                    <i class="bi bi-person-plus me-2"></i>Register
                </a>
            </div>
        }

        <div class="alert alert-info mt-5 text-start" role="alert">
            <h5><i class="bi bi-info-circle me-2"></i>Demo Credentials</h5>
            <p class="mb-1"><strong>Admin:</strong> admin@readystatus.com / Admin123</p>
            <p class="mb-0"><strong>User:</strong> Register a new account or use the demo</p>
        </div>
    </div>
</div>
